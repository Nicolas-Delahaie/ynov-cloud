# Modèle de configuration — copier en `.env` puis adapter :
#   cp .env.example .env
# Le vrai `.env` est git-ignoré (pas de credentials dans Git).

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=worldcup2026

# GitHub — Classic Personal Access Token avec le scope write:packages
# https://github.com/settings/tokens > Generate new token (classic)
GITHUB_TOKEN=

# Grafana (bloc 4 — observabilité) — mot de passe admin
# Passé au déploiement : --set grafana.adminPassword="$GRAFANA_ADMIN_PASSWORD"
GRAFANA_ADMIN_PASSWORD=
